# ── ESIManage Pro — Variables d'environnement ──

# Lien de connexion PostgreSQL (Neon, AWS RDS, etc.)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Port du serveur backend (par defaut 3001 en local, Render definit 10000)
PORT=3001

# Cle secrete pour signer les tokens JWT (obligatoire en production !)
# Generer une cle forte avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGEZ-MOI-PAR-UNE-CLE-FORTE-EN-PRODUCTION

# ── ESIManage Pro — Variables d'environnement ──

# Lien de connexion PostgreSQL (Neon, AWS RDS, etc.)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

